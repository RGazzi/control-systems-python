      "source": [
        "m=1\n",
        "b=2\n",
        "k=4\n",
        "\n",
        "#função-transferência - sist massa, mola, amortecedor\n",
        "plant_tf = TransferFunction(1, [m,b,k])\n",
        "plant_tf\n",
        "\n",
        "#polos do sistema\n",
        "polos = ctl.poles(plant_tf)\n",
        "print(\"Polos: \")\n",
        "print(polos)\n",
        "\n",
        "#frequência natural e fator de amortecimento\n",
        "print(\"Damping: \")\n",
        "ctl.damp(plant_tf, doprint=True)"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "#frequencia abaixo de de wn=1\n",
        "\n",
        "y0 = [0.0, 0.0]\n",
        "t = np.linspace(0, 20, 1001)\n",
        "w=1 #frequencia em rad\n",
        "u=np.sin(w*t) #entrada senoidal\n",
        "\n",
        "#resposta forçada\n",
        "xout, yout = ctl.forced_response(plant_tf, U=u, T=t) #planta, entrada e vetor tempo\n",
        "plt.plot(t, u, 'r--', linewidth=1.5, label='entrada')\n",
        "plt.plot(t, yout, 'k', linewidth=1.5, label='resposta')\n",
        "plt.legend(loc='best', shadow=True, framealpha=1)\n",
        "plt.grid(alpha=0.1)\n",
        "plt.xlabel('t(s)')\n",
        "plt.ylabel('amplitude')\n",
        "plt.show()"
